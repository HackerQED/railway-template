# -----------------------------------------------------------------------------
# Webhook Base URL
# Public URL for receiving webhooks from upstream providers (e.g., MaxAPI).
# Production: set to your domain, e.g. https://yino.ai
# Development: use a tunnel, e.g. https://dev.yino.ai via `cloudflared tunnel`
# -----------------------------------------------------------------------------
WEBHOOK_BASE_URL=""

# -----------------------------------------------------------------------------
# Mock Mode
# When MOCK is not set or not "false", all external AI calls are mocked.
# Set MOCK=false to use real API calls (requires valid API keys above).
# Set MOCK_BYPASS to bypass mock for specific stages (comma-separated).
# Stages: analysis, direction, storyboard, shots, compose
# Example: MOCK_BYPASS="direction" — only direction uses real API, others mock.
# -----------------------------------------------------------------------------
MOCK=""
MOCK_BYPASS=""

# -----------------------------------------------------------------------------
# Web Content Analyzer (Firecrawl)
# https://firecrawl.dev/
# -----------------------------------------------------------------------------
FIRECRAWL_API_KEY=""
